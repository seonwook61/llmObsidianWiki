---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, groupByCategory } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return groupByCategory(posts).map(([category]) => ({
    params: { category }
  }));
}

const posts = await getPublishedPosts();
const category = Astro.params.category!;
const filteredPosts = posts.filter((post) => post.category === category);
---

<BaseLayout title={`${category} | Categories`}>
  <section class="panel">
    <p class="eyebrow">Category</p>
    <h1>{category}</h1>
    <p class="muted">{filteredPosts.length} published post{filteredPosts.length === 1 ? "" : "s"}.</p>
  </section>

  <section class="section list">
    {filteredPosts.map((post) => (
      <article class="panel">
        <div class="meta">
          <span>{post.date}</span>
          <span>{post.domain}</span>
        </div>
        <h2><a href={post.url}>{post.title}</a></h2>
        <p class="muted">{post.summary}</p>
        <div class="tag-row">
          {post.tags.map((tag) => (
            <a class="tag" href={`/tags/${tag}/`}>#{tag}</a>
          ))}
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
