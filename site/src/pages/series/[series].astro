---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, groupBySeries } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return groupBySeries(posts).map(([series]) => ({
    params: { series }
  }));
}

const posts = await getPublishedPosts();
const series = Astro.params.series!;
const filteredPosts = posts.filter((post) => post.series === series);
---

<BaseLayout title={`${series} | Series`}>
  <section class="panel">
    <p class="eyebrow">Series</p>
    <h1>{series}</h1>
    <p class="muted">{filteredPosts.length} published post{filteredPosts.length === 1 ? "" : "s"} in this series.</p>
  </section>

  <section class="section list">
    {filteredPosts.map((post) => (
      <article class="panel">
        <div class="meta">
          <span>{post.date}</span>
          <span>{post.domain}</span>
          <span>{post.category}</span>
        </div>
        <h2><a href={post.url}>{post.title}</a></h2>
        <p class="muted">{post.summary}</p>
      </article>
    ))}
  </section>
</BaseLayout>
