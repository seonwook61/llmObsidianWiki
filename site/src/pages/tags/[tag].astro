---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, groupByTag } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return groupByTag(posts).map(([tag]) => ({
    params: { tag }
  }));
}

const posts = await getPublishedPosts();
const tag = Astro.params.tag!;
const filteredPosts = posts.filter((post) => post.tags.includes(tag));
---

<BaseLayout title={`#${tag} | Tags`}>
  <section class="panel">
    <p class="eyebrow">Tag</p>
    <h1>#{tag}</h1>
    <p class="muted">{filteredPosts.length} published post{filteredPosts.length === 1 ? "" : "s"}.</p>
  </section>

  <section class="section list">
    {filteredPosts.map((post) => (
      <article class="panel">
        <div class="meta">
          <span>{post.date}</span>
          <span>{post.domain}</span>
          <span>{post.category}</span>
        </div>
        <h2><a href={post.url}>{post.title}</a></h2>
        <p class="muted">{post.summary}</p>
      </article>
    ))}
  </section>
</BaseLayout>
