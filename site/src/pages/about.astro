---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | llm-wiki master">
  <section class="post-shell">
    <p class="eyebrow">About</p>
    <h1>About this site</h1>
    <article>
      <p>
        This site is the public layer of an Obsidian-based master vault. Private capture stays in journals,
        durable thinking stays in the wiki, and public writing is promoted into a separate publish layer before deployment.
      </p>
      <p>
        The goal is simple: write consistently, learn in public when useful, and keep the internal knowledge system cleaner than the public feed.
      </p>
    </article>
  </section>
</BaseLayout>
