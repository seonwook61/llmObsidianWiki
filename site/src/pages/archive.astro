---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublishedPosts, groupByMonth } from "../lib/posts";

const posts = await getPublishedPosts();
const months = groupByMonth(posts);
---

<BaseLayout title="Archive | llm-wiki master">
  <section class="panel">
    <p class="eyebrow">Archive</p>
    <h1>Archive</h1>
    <p class="muted">Browse posts by month.</p>
  </section>

  <section class="section list">
    {months.map(([month, monthPosts]) => (
      <article class="panel">
        <h2>{month}</h2>
        <div class="list">
          {monthPosts.map((post) => (
            <div class="list-item">
              <div class="meta">
                <span>{post.date}</span>
                <span>{post.domain}</span>
                <span>{post.category}</span>
              </div>
              <h3><a href={post.url}>{post.title}</a></h3>
              <p class="muted">{post.summary}</p>
            </div>
          ))}
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
